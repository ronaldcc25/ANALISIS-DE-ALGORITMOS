<mxfile host="app.diagrams.net">
  <diagram name="Página-1" id="QWH7Hj5IjTxEEYnEt72y">
    <mxGraphModel dx="2943" dy="1620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    %% Módulo 1 y 2: Identidad, Triaje y Herencia Base\n    class Usuario {\n        +String idUsuario\n        +String nombres\n        +String apellidos\n        +String correo\n        +String tipoUsuario\n        +String datosDemograficos\n        +String estadoRiesgo\n        +gestionarCuenta()\n        +iniciarSolicitud()\n        +solicitarAnalisisNLP()\n        +ingresarSintomas()\n    }\n\n    class Paciente {\n        +String idPaciente\n        +String historialClinicoBasico\n        +boolean aceptaLOPDP\n        +solicitarAsistenciaPropia()\n        +reportarSintomasPropios()\n        +participarTeleconsultaAsistida()\n        +participarMonitoreoContinuo()\n        +atenderSeguimientoProactivo()\n    }\n\n    class Familiar {\n        +String idFamiliar\n        +String relacionConPaciente\n        +String datosContacto\n        +solicitarAsistenciaTercero()\n        +reportarSintomasTercero()\n    }\n\n    class SistemaIAM {\n        +String idValidacion\n        +String tokenJWT\n        +String estadoCredenciales\n        +validarIdentidad()\n        +verificarPerfil()\n    }\n\n    %% Inteligencia Artificial y Bases de Conocimiento\n    class LLM_Claude {\n        +String idInferencia\n        +String promptEntrada\n        +String respuestaGenerada\n        +String estadoConexion\n        +String nivelUrgencia\n        +String estadoDerivacion\n        +String contextoPaciente\n        +String textoRecetaGenerado\n        +procesarRecepcionMultimodal()\n        +transcribirVoz()\n        +analizarTexto()\n        +realizarAnalisisNLP()\n        +generarPreDiagnostico()\n        +brindarContencionClinica()\n        +generarResumenInteligente()\n        +asistirEmisionFirmaReceta()\n    }\n\n    class BaseAyudaRAG {\n        +String idDocumento\n        +String contenidoOrientacion\n        +String vectorContexto\n        +brindarOrientacionInteractiva()\n        +recuperarInstruccionesUso()\n    }\n\n    class BaseMedicaRAGClinico {\n        +String idContexto\n        +String protocolosMedicos\n        +String vectorSimilitud\n        +proveerContextoClinico()\n        +validarSintomasRAG()\n    }\n\n    %% Infraestructura IoT y Logística\n    class SensoresIoT {\n        +String idSensor\n        +String tipoBiometria\n        +Float valorLectura\n        +Date timestamp\n        +capturarLecturaBiometricaInmediata()\n        +transmitirTelemetria()\n    }\n\n    class CM {\n        +String idCentro\n        +String especialidad\n        +boolean disponibilidad\n        +String ubicacionGeografica\n        +recibirDerivacionSegura()\n        +procesarMatchingInteligente()\n    }\n\n    %% Módulo 3: Especialista y Tratamiento\n    class MedicoEspecialista {\n        +String idMedico\n        +String credencialesAcceso\n        +String firmaElectronica\n        +accederPanelRevision()\n        +validarAlertasDiagnostico()\n        +realizarTeleconsultaAsistida()\n        +emitirFirmaReceta()\n    }\n\n    class EntidadCertificadora {\n        +String idEntidad\n        +String llavePublica\n        +String estadoCertificado\n        +validarFirmaElectronica()\n    }\n\n    %% Módulo 4: Monitoreo Predictivo y Auditoría\n    class AuditorMedico_DPO {\n        +String idAuditor\n        +String credencialesAcceso\n        +String nivelPermisos\n        +auditarRepositorioInmutable()\n    }\n\n    class MSP_IESS {\n        +String idEntidadSalud\n        +String endpointInteroperabilidad\n        +sincronizarConRedPublica()\n    }\n\n    class MotorML_PredictivoIoT {\n        +String idModelo\n        +Float umbralAnomalia\n        +String estadoProcesamiento\n        +procesarMonitoreoContinuo()\n        +emitirAlertaTemprana()\n    }\n\n    class LLM_BotSeguimiento {\n        +String idInstanciaBot\n        +String registroEvolucion\n        +String contextoClinico\n        +realizarSeguimientoProactivo()\n    }\n\n    %% --- RELACIONES ESTRUCTURALES ---\n\n    %% Herencia (Polimorfismo)\n    Usuario &lt;|-- Paciente\n    Usuario &lt;|-- Familiar\n\n    %% Asociaciones Modulo 1 y 2\n    Usuario \&quot;1\&quot; -- \&quot;1\&quot; SistemaIAM\n    Usuario \&quot;1\&quot; -- \&quot;1\&quot; LLM_Claude\n    Usuario \&quot;1\&quot; -- \&quot;N\&quot; SensoresIoT\n\n    LLM_Claude \&quot;1\&quot; -- \&quot;N\&quot; BaseAyudaRAG\n    LLM_Claude \&quot;1\&quot; -- \&quot;1\&quot; BaseMedicaRAGClinico\n    LLM_Claude \&quot;1\&quot; -- \&quot;N\&quot; CM\n\n    %% Asociaciones Modulo 3 (Corregidas de Herencia a Asociación)\n    MedicoEspecialista \&quot;1\&quot; -- \&quot;1\&quot; Paciente\n    MedicoEspecialista \&quot;1\&quot; -- \&quot;1\&quot; LLM_Claude\n    MedicoEspecialista \&quot;N\&quot; -- \&quot;1\&quot; EntidadCertificadora\n\n    %% Asociaciones Modulo 4 (Corregidas de Herencia a Asociación)\n    AuditorMedico_DPO \&quot;N\&quot; -- \&quot;1\&quot; MSP_IESS\n    Paciente \&quot;1\&quot; -- \&quot;N\&quot; MotorML_PredictivoIoT\n    Paciente \&quot;1\&quot; -- \&quot;N\&quot; LLM_BotSeguimiento&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="urHZTqmzEeDbbfFkow2d-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
